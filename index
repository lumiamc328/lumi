<!DOCTYPE html>\n<html lang=\"zh-TW\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>路米動物醫院｜進出貨管理系統<\/title>\n<style>\n\/* ─── RESET ─────────────────────────────── *\/\n*{box-sizing:border-box;margin:0;padding:0}\nbody{font-family:-apple-system,BlinkMacSystemFont,\"Helvetica Neue\",Arial,sans-serif;\n     background:#f5f2eb;color:#1e1c18;font-size:14px;min-height:100vh}\n\n\/* ─── VARIABLES ─────────────────────────── *\/\n:root{\n  --bg:#f5f2eb;--sur:#fffef9;--sur2:#f0ede4;--bor:#d6cfc0;\n  --drug:#3a6b4a;--supply:#3a5e8c;--lab:#7b4fa0;--food:#b06a2a;\n  --warn:#c4763a;--danger:#b94040;--t2:#5a5649;--t3:#8a8275;\n  --sh:0 2px 10px rgba(0,0,0,0.07)\n}\n\n\/* ─── LAYOUT ─────────────────────────────── *\/\n#hdr{\n  background:var(--drug);color:#fff;height:60px;\n  display:flex;align-items:center;justify-content:space-between;\n  padding:0 22px;position:sticky;top:0;z-index:100;\n  box-shadow:0 2px 12px rgba(0,0,0,0.18)\n}\n#hdr-l{display:flex;align-items:center;gap:11px}\n#logo{width:36px;height:36px;background:rgba(255,255,255,0.18);border-radius:50%;\n      display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}\n#app-title{font-size:16px;font-weight:700;letter-spacing:.03em}\n#app-sub{font-size:10px;opacity:.7;margin-top:1px}\n#hdr-r{display:flex;align-items:center;gap:9px}\n#sync-btn-hdr{\n  background:rgba(255,255,255,0.18);border:1.5px solid rgba(255,255,255,0.4);\n  color:#fff;padding:6px 13px;border-radius:7px;cursor:pointer;\n  font-size:12.5px;font-weight:500;display:flex;align-items:center;gap:5px;\n  font-family:inherit\n}\n#clock{font-size:11.5px;opacity:.75}\n\n#app{display:flex;height:calc(100vh - 60px);overflow:hidden}\n\n\/* ─── SIDEBAR ─────────────────────────────── *\/\n#sidebar{\n  width:195px;background:var(--sur);border-right:1px solid var(--bor);\n  display:flex;flex-direction:column;padding:10px 0;flex-shrink:0;overflow-y:auto\n}\n.nlbl{font-size:9.5px;color:var(--t3);letter-spacing:.12em;text-transform:uppercase;\n      padding:10px 12px 4px;font-weight:700}\n.nsec{padding:0 8px}\n.nb{\n  width:100%;background:none;border:none;text-align:left;\n  padding:8px 10px;border-radius:7px;cursor:pointer;\n  font-size:13px;color:var(--t2);display:flex;align-items:center;gap:8px;\n  margin-bottom:2px;font-family:inherit;transition:background .12s\n}\n.nb:hover{background:var(--sur2);color:#1e1c18}\n.nb.on{background:var(--drug);color:#fff}\n.nhr{border:none;border-top:1px solid var(--bor);margin:7px 10px}\n\n\/* ─── MAIN ─────────────────────────────────── *\/\n#main{flex:1;overflow-y:auto;padding:22px 26px;background:var(--bg)}\n.pg{display:none}.pg.on{display:block}\n.pg-ttl{font-size:20px;font-weight:700;margin-bottom:4px}\n.pg-sub{font-size:12px;color:var(--t3);margin-bottom:20px}\n\n\/* ─── CAT SWITCHER ─────────────────────────── *\/\n.csw{\n  display:flex;flex-wrap:wrap;gap:3px;margin-bottom:16px;\n  background:var(--sur2);border-radius:9px;padding:4px;\n  border:1px solid var(--bor);width:fit-content\n}\n.cb{\n  padding:7px 14px;border:none;border-radius:6px;cursor:pointer;\n  font-size:12.5px;font-weight:500;background:none;color:var(--t3);\n  white-space:nowrap;font-family:inherit;display:flex;align-items:center;gap:5px\n}\n\n\/* ─── CARDS ─────────────────────────────────── *\/\n.card{\n  background:var(--sur);border:1px solid var(--bor);border-radius:10px;\n  padding:20px;margin-bottom:16px;box-shadow:var(--sh)\n}\n.card-ttl{font-size:13.5px;font-weight:700;margin-bottom:14px;\n           display:flex;align-items:center;gap:7px}\n.dot{width:8px;height:8px;border-radius:50%;display:inline-block;flex-shrink:0}\n\n\/* ─── STATS ─────────────────────────────────── *\/\n.sg{display:grid;gap:12px;margin-bottom:14px}\n.sc{\n  background:var(--sur);border:1px solid var(--bor);border-radius:10px;\n  padding:14px 16px;box-shadow:var(--sh)\n}\n.sv{font-size:25px;font-weight:600}\n.sl{font-size:11px;color:var(--t3);margin-top:2px}\n\n\/* ─── FORM ──────────────────────────────────── *\/\n.fg2{display:grid;grid-template-columns:1fr 1fr;gap:13px}\n.fg4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:13px}\n.fg{display:flex;flex-direction:column;gap:5px}\n.lbl{font-size:11.5px;color:var(--t2);font-weight:600;display:block;margin-bottom:0}\ninput,select{\n  font-family:inherit;font-size:13px;padding:8px 10px;\n  border:1.5px solid var(--bor);border-radius:7px;\n  background:var(--bg);color:#1e1c18;outline:none;width:100%;\n  -webkit-appearance:none;appearance:none\n}\ninput:focus,select:focus{border-color:var(--drug);background:var(--sur);\n  box-shadow:0 0 0 3px rgba(58,107,74,.1)}\ninput[readonly]{background:var(--sur2)!important;cursor:default}\n.irow{display:flex;gap:6px}\n.irow input{flex:1}\n.usel{width:75px!important;flex:none!important}\n.pfx{display:flex}\n.pfx-l{\n  padding:8px 9px;background:var(--sur2);border:1.5px solid var(--bor);\n  border-right:none;border-radius:7px 0 0 7px;font-size:12px;color:var(--t3);\n  white-space:nowrap;display:flex;align-items:center\n}\n.pfx input{border-radius:0 7px 7px 0}\n\n\/* ─── BUTTONS ───────────────────────────────── *\/\n.btn{\n  font-family:inherit;font-size:13px;font-weight:500;padding:8px 16px;\n  border-radius:7px;border:none;cursor:pointer;\n  display:inline-flex;align-items:center;gap:6px\n}\n.btn-ghost{background:var(--sur2);color:#1e1c18;border:1.5px solid var(--bor)}\n.btn-sm{padding:5px 10px;font-size:11.5px}\n.brow{display:flex;gap:8px;margin-top:16px;flex-wrap:wrap}\n\n\/* ─── AUTOCOMPLETE ──────────────────────────── *\/\n.acw{position:relative}\n.acl{\n  position:absolute;top:100%;left:0;right:0;z-index:60;\n  background:var(--sur);border:1.5px solid var(--drug);\n  border-top:none;border-radius:0 0 8px 8px;\n  max-height:190px;overflow-y:auto;box-shadow:var(--sh);display:none\n}\n.acl.on{display:block}\n.aci{\n  padding:8px 11px;cursor:pointer;font-size:13px;\n  display:flex;justify-content:space-between;align-items:center\n}\n.aci:hover{background:var(--sur2)}\n.aci-s{font-size:11px;color:var(--t3)}\n\n\/* ─── VENDOR TAGS ───────────────────────────── *\/\n.vtags{display:flex;flex-wrap:wrap;gap:5px;margin-top:7px}\n.vtag{\n  padding:3px 9px;border-radius:20px;font-size:11.5px;\n  border:1.5px solid var(--bor);cursor:pointer;\n  background:var(--bg);color:var(--t2);font-family:inherit\n}\n.vtag.on{border-color:var(--drug);background:rgba(58,107,74,.08);\n          color:var(--drug);font-weight:600}\n\n\/* ─── TABLE ─────────────────────────────────── *\/\n.twrap{overflow-x:auto;border-radius:8px;border:1px solid var(--bor)}\ntable{width:100%;border-collapse:collapse;font-size:12.5px}\nth{\n  background:var(--sur2);padding:9px 12px;text-align:left;\n  font-size:10.5px;font-weight:700;color:var(--t2);letter-spacing:.04em;\n  border-bottom:1.5px solid var(--bor);white-space:nowrap\n}\ntd{padding:9px 12px;border-bottom:1px solid var(--bor);vertical-align:middle}\ntr:last-child td{border-bottom:none}\ntr:hover td{background:rgba(240,237,228,.5)}\n.tm{font-size:12px}\n.tbold{font-weight:600}\ntr.rl td{background:rgba(196,118,58,.04)}\ntr.re td{background:rgba(185,64,64,.04)}\n\n\/* ─── BADGES ─────────────────────────────────── *\/\n.badge{\n  display:inline-flex;align-items:center;\n  padding:2px 8px;border-radius:20px;font-size:10.5px;font-weight:700\n}\n\n\/* ─── TABS ──────────────────────────────────── *\/\n.tabs{display:flex;flex-wrap:wrap;border-bottom:2px solid var(--bor);margin-bottom:16px}\n.tabb{\n  background:none;border:none;padding:8px 13px;font-size:13px;\n  cursor:pointer;color:var(--t3);border-bottom:2px solid transparent;\n  margin-bottom:-2px;font-family:inherit\n}\n.tabb.on{color:var(--drug);border-bottom-color:var(--drug);font-weight:700}\n\n\/* ─── PROFIT CHIP ───────────────────────────── *\/\n.pc{display:inline-flex;font-size:11px;padding:2px 7px;border-radius:5px}\n\n\/* ─── MISC ──────────────────────────────────── *\/\n.expbar{display:flex;justify-content:flex-end;gap:8px;margin-bottom:13px}\n.sbar{display:flex;gap:8px;margin-bottom:13px}\n.sbar input{flex:1}\n.empty{text-align:center;padding:36px 20px;color:var(--t3)}\n\n\/* ─── TOAST ─────────────────────────────────── *\/\n#toast{\n  position:fixed;bottom:22px;right:22px;\n  color:#fff;padding:10px 18px;border-radius:9px;\n  font-size:13.5px;font-weight:500;\n  box-shadow:0 4px 16px rgba(0,0,0,.15);\n  display:none;z-index:9999;pointer-events:none;\n  transition:opacity .3s\n}\n\n\/* ─── MODAL OVERLAY ─────────────────────────── *\/\n.overlay{\n  display:none;position:fixed;inset:0;\n  background:rgba(30,28,24,.55);z-index:200;\n  align-items:center;justify-content:center\n}\n.overlay.on{display:flex}\n.modal{\n  background:var(--sur);border-radius:13px;padding:26px;\n  width:460px;max-width:92vw;\n  box-shadow:0 8px 36px rgba(0,0,0,.2)\n}\n#sync-status{\n  margin-top:13px;padding:11px 13px;border-radius:8px;\n  font-size:13px;display:none;line-height:1.7;white-space:pre-line\n}\n\n\/* ─── RESPONSIVE ─────────────────────────────── *\/\n@media(max-width:1050px){.fg4{grid-template-columns:1fr 1fr}}\n@media(max-width:680px){\n  #sidebar{width:46px}\n  .nb span:not(:first-child){display:none}\n  .nlbl,.nhr+.nsec .nb span:not(:first-child){display:none}\n  .nlbl{display:none}\n  #main{padding:12px}\n  .fg4,.fg2{grid-template-columns:1fr}\n}\n<\/style>\n<\/head>\n<body>\n\n<!-- ═══ HEADER ════════════════════════════════════ -->\n<div id=\"hdr\">\n  <div id=\"hdr-l\">\n    <div id=\"logo\">🐾<\/div>\n    <div>\n      <div id=\"app-title\">路米動物醫院<\/div>\n      <div id=\"app-sub\">進出貨管理系統 · INVENTORY MANAGEMENT<\/div>\n    <\/div>\n  <\/div>\n  <div id=\"hdr-r\">\n    <button id=\"sync-btn-hdr\" onclick=\"openSync()\">🔄 同步試算表<\/button>\n    <div id=\"clock\"><\/div>\n  <\/div>\n<\/div>\n\n<div id=\"app\">\n\n<!-- ═══ SIDEBAR ═══════════════════════════════════ -->\n<div id=\"sidebar\">\n  <div class=\"nlbl\">功能選單<\/div>\n  <div class=\"nsec\">\n    <button class=\"nb on\" id=\"nb-dashboard\" onclick=\"gp('dashboard')\"><span>📊<\/span><span>總覽<\/span><\/button>\n    <button class=\"nb\" id=\"nb-inbound\"   onclick=\"gp('inbound')\"><span>📦<\/span><span>進貨登記<\/span><\/button>\n    <button class=\"nb\" id=\"nb-outbound\"  onclick=\"gp('outbound')\"><span>🚚<\/span><span>出貨／使用<\/span><\/button>\n    <button class=\"nb\" id=\"nb-query\"     onclick=\"gp('query')\"><span>🔍<\/span><span>庫存查詢<\/span><\/button>\n    <button class=\"nb\" id=\"nb-history\"   onclick=\"gp('history')\"><span>📋<\/span><span>歷史紀錄<\/span><\/button>\n  <\/div>\n  <div class=\"nhr\"><\/div>\n  <div class=\"nsec\">\n    <button class=\"nb\" onclick=\"exportCSV()\"><span>⬇️<\/span><span>匯出 CSV<\/span><\/button>\n  <\/div>\n<\/div>\n\n<!-- ═══ MAIN ═══════════════════════════════════════ -->\n<div id=\"main\">\n\n<!-- DASHBOARD -->\n<div class=\"pg on\" id=\"pg-dashboard\">\n  <div class=\"pg-ttl\">📊 庫存總覽<\/div>\n  <div class=\"pg-sub\">即時掌握各類藥品與耗材庫存狀態<\/div>\n  <div class=\"sg\" style=\"grid-template-columns:repeat(4,1fr)\" id=\"stats-cats\"><\/div>\n  <div class=\"sg\" style=\"grid-template-columns:repeat(3,1fr);margin-top:-4px\">\n    <div class=\"sc\"><div class=\"sv\" id=\"s-vendors\">0<\/div><div class=\"sl\">🏭 廠商數量<\/div><\/div>\n    <div class=\"sc\" style=\"border-left:3px solid var(--warn)\"><div class=\"sv\" id=\"s-low\">0<\/div><div class=\"sl\">⚠ 低庫存警示<\/div><\/div>\n    <div class=\"sc\" style=\"border-left:3px solid var(--danger)\"><div class=\"sv\" id=\"s-exp\">0<\/div><div class=\"sl\">⛔ 即將到期（30天）<\/div><\/div>\n  <\/div>\n  <div id=\"dash-tables\"><\/div>\n<\/div>\n\n<!-- INBOUND -->\n<div class=\"pg\" id=\"pg-inbound\">\n  <div class=\"pg-ttl\">📦 進貨登記<\/div>\n  <div class=\"pg-sub\">登記各類品項進貨，支援品名快速搜尋與廠商記憶<\/div>\n  <div class=\"csw\" id=\"in-csw\"><\/div>\n  <div class=\"card\">\n    <div class=\"card-ttl\"><span class=\"dot\" id=\"in-sdot\"><\/span>品名搜尋（已登記品項可快速填入）<\/div>\n    <div class=\"acw\">\n      <input type=\"text\" id=\"in-srch\" placeholder=\"輸入品名搜尋或新增...\" autocomplete=\"off\" oninput=\"searchIn()\">\n      <div class=\"acl\" id=\"in-ac\"><\/div>\n    <\/div>\n    <div id=\"in-vtag-area\" style=\"display:none\">\n      <div style=\"font-size:11.5px;color:var(--t3);margin-top:7px\">此品項曾用廠商：<\/div>\n      <div class=\"vtags\" id=\"in-vtags\"><\/div>\n    <\/div>\n  <\/div>\n  <div class=\"card\">\n    <div class=\"card-ttl\"><span class=\"dot\" id=\"in-fdot\"><\/span>進貨資料<\/div>\n    <div class=\"fg4\">\n      <div class=\"fg\"><span class=\"lbl\">品名 *<\/span><input type=\"text\" id=\"in-name\" placeholder=\"品名\"><\/div>\n      <div class=\"fg\"><span class=\"lbl\">廠商 *<\/span><input type=\"text\" id=\"in-vendor\" placeholder=\"廠商名稱\"><\/div>\n      <div class=\"fg\"><span class=\"lbl\">進貨日期 *<\/span><input type=\"date\" id=\"in-date\"><\/div>\n      <div class=\"fg\"><span class=\"lbl\">有效期限<\/span><input type=\"date\" id=\"in-expiry\"><\/div>\n      <div class=\"fg\">\n        <span class=\"lbl\">進貨數量 *<\/span>\n        <div class=\"irow\">\n          <input type=\"number\" id=\"in-qty\" placeholder=\"數量\" min=\"0\">\n          <select id=\"in-unit\" class=\"usel\"><\/select>\n        <\/div>\n      <\/div>\n      <div class=\"fg\">\n        <span class=\"lbl\">進貨成本（單價）<\/span>\n        <div class=\"pfx\"><div class=\"pfx-l\">NT$<\/div><input type=\"number\" id=\"in-cost\" placeholder=\"0\" min=\"0\" step=\"0.01\"><\/div>\n      <\/div>\n      <div class=\"fg\">\n        <span class=\"lbl\">售價（單價）<\/span>\n        <div class=\"pfx\"><div class=\"pfx-l\">NT$<\/div><input type=\"number\" id=\"in-price\" placeholder=\"0\" min=\"0\" step=\"0.01\"><\/div>\n      <\/div>\n      <div class=\"fg\"><span class=\"lbl\">批號 \/ 備註<\/span><input type=\"text\" id=\"in-note\" placeholder=\"選填\"><\/div>\n    <\/div>\n    <div class=\"brow\">\n      <button class=\"btn\" id=\"in-submit\" onclick=\"submitIn()\">✅ 確認進貨登記<\/button>\n      <button class=\"btn btn-ghost\" onclick=\"clearIn(false)\">清除<\/button>\n    <\/div>\n  <\/div>\n<\/div>\n\n<!-- OUTBOUND -->\n<div class=\"pg\" id=\"pg-outbound\">\n  <div class=\"pg-ttl\">🚚 出貨／使用登記<\/div>\n  <div class=\"pg-sub\">記錄各類品項使用與出貨，即時更新庫存<\/div>\n  <div class=\"csw\" id=\"out-csw\"><\/div>\n  <div class=\"card\">\n    <div class=\"card-ttl\"><span class=\"dot\" id=\"out-sdot\"><\/span>搜尋品項<\/div>\n    <div class=\"acw\">\n      <input type=\"text\" id=\"out-srch\" placeholder=\"輸入品名搜尋...\" autocomplete=\"off\" oninput=\"searchOut()\">\n      <div class=\"acl\" id=\"out-ac\"><\/div>\n    <\/div>\n    <div id=\"out-info\" style=\"display:none;margin-top:10px;font-size:12.5px;line-height:2;color:var(--t2)\"><\/div>\n  <\/div>\n  <div class=\"card\">\n    <div class=\"card-ttl\"><span class=\"dot\" id=\"out-fdot\"><\/span>出貨資料<\/div>\n    <div class=\"fg2\">\n      <div class=\"fg\"><span class=\"lbl\">品名<\/span><input type=\"text\" id=\"out-name\" readonly><\/div>\n      <div class=\"fg\"><span class=\"lbl\">出貨日期 *<\/span><input type=\"date\" id=\"out-date\"><\/div>\n      <div class=\"fg\">\n        <span class=\"lbl\">數量 *<\/span>\n        <div class=\"irow\">\n          <input type=\"number\" id=\"out-qty\" placeholder=\"數量\" min=\"1\">\n          <input type=\"text\" id=\"out-unit\" class=\"usel\" readonly>\n        <\/div>\n      <\/div>\n      <div class=\"fg\"><span class=\"lbl\">用途 \/ 病患<\/span><input type=\"text\" id=\"out-note\" placeholder=\"例：治療用、病患名稱...\"><\/div>\n    <\/div>\n    <div class=\"brow\">\n      <button class=\"btn\" id=\"out-submit\" onclick=\"submitOut()\">✅ 確認出貨登記<\/button>\n      <button class=\"btn btn-ghost\" onclick=\"clearOut()\">清除<\/button>\n    <\/div>\n  <\/div>\n<\/div>\n\n<!-- QUERY -->\n<div class=\"pg\" id=\"pg-query\">\n  <div class=\"pg-ttl\">🔍 庫存查詢<\/div>\n  <div class=\"pg-sub\">依品名查詢現有庫存、成本售價及進出貨紀錄<\/div>\n  <div class=\"csw\" id=\"q-csw\"><\/div>\n  <div class=\"card\">\n    <div class=\"sbar\"><input type=\"text\" id=\"q-input\" placeholder=\"輸入品名搜尋...\" oninput=\"renderQ()\"><\/div>\n  <\/div>\n  <div id=\"q-result\"><\/div>\n<\/div>\n\n<!-- HISTORY -->\n<div class=\"pg\" id=\"pg-history\">\n  <div class=\"pg-ttl\">📋 歷史紀錄<\/div>\n  <div class=\"pg-sub\">所有進出貨記錄<\/div>\n  <div class=\"tabs\" id=\"hist-tabs\"><\/div>\n  <div class=\"expbar\">\n    <button class=\"btn btn-ghost btn-sm\" onclick=\"exportCSV()\">⬇️ 匯出 CSV<\/button>\n  <\/div>\n  <div class=\"card\" style=\"padding:0;overflow:hidden\">\n    <div class=\"twrap\" style=\"border:none\">\n      <table>\n        <thead><tr>\n          <th>日期<\/th><th>類型<\/th><th>分類<\/th><th>品名<\/th><th>廠商<\/th>\n          <th>數量<\/th><th>進貨成本<\/th><th>售價<\/th><th>有效期限<\/th><th>備註<\/th><th>操作<\/th>\n        <\/tr><\/thead>\n        <tbody id=\"hist-body\"><\/tbody>\n      <\/table>\n    <\/div>\n  <\/div>\n<\/div>\n\n<\/div><!-- #main -->\n<\/div><!-- #app -->\n\n<!-- ═══ SYNC MODAL ══════════════════════════════════ -->\n<div class=\"overlay\" id=\"sync-overlay\" onclick=\"if(event.target===this)closeSync()\">\n  <div class=\"modal\">\n    <div style=\"font-size:18px;font-weight:700;margin-bottom:4px\">🔄 同步到 Google 試算表<\/div>\n    <div style=\"font-size:12.5px;color:var(--t3);margin-bottom:18px\">將所有進出貨紀錄同步至您的 Google 試算表<\/div>\n    <div class=\"fg\">\n      <span class=\"lbl\">Google Apps Script 網址<\/span>\n      <div style=\"display:flex;gap:7px;margin-top:4px\">\n        <input type=\"text\" id=\"sync-url\" placeholder=\"https:\/\/script.google.com\/macros\/s\/…\/exec\">\n        <button class=\"btn btn-ghost btn-sm\" onclick=\"saveUrl()\">儲存<\/button>\n      <\/div>\n      <div style=\"font-size:11px;color:var(--t3);margin-top:3px\">網址以 https:\/\/script.google.com\/macros\/s\/ 開頭<\/div>\n    <\/div>\n    <div id=\"sync-status\"><\/div>\n    <div style=\"display:flex;gap:8px;margin-top:18px;justify-content:flex-end;flex-wrap:wrap\">\n      <button class=\"btn btn-ghost btn-sm\" onclick=\"testConn()\">🔌 測試連線<\/button>\n      <button class=\"btn btn-ghost btn-sm\" onclick=\"initSheets()\">📋 初始化試算表<\/button>\n      <button class=\"btn\" id=\"do-sync-btn\" style=\"background:var(--drug);color:#fff\" onclick=\"doSync()\">🔄 立即同步<\/button>\n      <button class=\"btn btn-ghost btn-sm\" onclick=\"closeSync()\">關閉<\/button>\n    <\/div>\n    <div style=\"margin-top:16px;padding:12px;background:var(--sur2);border-radius:8px;font-size:11.5px;color:var(--t3);line-height:1.9\">\n      <strong style=\"color:var(--t2)\">首次使用步驟：<\/strong><br>\n      1️⃣ 貼上 Apps Script 網址並點「儲存」<br>\n      2️⃣ 點「測試連線」確認 ✅<br>\n      3️⃣ 點「初始化試算表」建立工作表<br>\n      4️⃣ 之後每次點「立即同步」即可\n    <\/div>\n  <\/div>\n<\/div>\n\n<div id=\"toast\"><\/div>\n\n<script>\n\/\/ ════════════════════════════════════════════════\n\/\/ CONFIG\n\/\/ ════════════════════════════════════════════════\nvar C = {\n  drug:   {n:'藥品',             i:'💊', u:['顆','粒','罐','瓶','包','盒','mg','ml'], c:'#3a6b4a'},\n  supply: {n:'醫療耗材',         i:'🩺', u:['個','條','支','包','箱','組','片','捲'],  c:'#3a5e8c'},\n  lab:    {n:'檢驗耗材',         i:'🔬', u:['個','片','支','包','盒','瓶','箱'],       c:'#7b4fa0'},\n  food:   {n:'處方飼料／預防藥', i:'🍖', u:['包','盒','瓶','箱','罐'],                 c:'#b06a2a'}\n};\nvar CATS = ['drug','supply','lab','food'];\n\n\/\/ ════════════════════════════════════════════════\n\/\/ STATE\n\/\/ ════════════════════════════════════════════════\nvar DB = load();\nvar inCat='drug', outCat='drug', qCat='drug', histTab='all';\n\nfunction load(){\n  try{ var s=localStorage.getItem('lumi_v3'); if(s){var d=JSON.parse(s); if(d&&d.length)return d;} }catch(e){}\n  return DEMO_DATA();\n}\nfunction save(){ localStorage.setItem('lumi_v3', JSON.stringify(DB)); }\nfunction today(){ return new Date().toISOString().split('T')[0]; }\n\n\/\/ ════════════════════════════════════════════════\n\/\/ CLOCK\n\/\/ ════════════════════════════════════════════════\nfunction tick(){\n  var n=new Date();\n  document.getElementById('clock').textContent =\n    n.toLocaleDateString('zh-TW')+'  '+n.toLocaleTimeString('zh-TW',{hour:'2-digit',minute:'2-digit'});\n}\ntick(); setInterval(tick,30000);\n\n\/\/ ════════════════════════════════════════════════\n\/\/ NAVIGATION\n\/\/ ════════════════════════════════════════════════\nfunction gp(id){\n  var pgs=document.querySelectorAll('.pg'), nbs=document.querySelectorAll('.nb');\n  for(var i=0;i<pgs.length;i++) pgs[i].classList.remove('on');\n  for(var i=0;i<nbs.length;i++) nbs[i].classList.remove('on');\n  document.getElementById('pg-'+id).classList.add('on');\n  document.getElementById('nb-'+id).classList.add('on');\n  if(id==='dashboard') renderDash();\n  if(id==='history')   renderHist();\n  if(id==='query')     renderQ();\n}\n\n\/\/ ════════════════════════════════════════════════\n\/\/ BUILD CATEGORY SWITCHERS & SIDEBAR (on load)\n\/\/ ════════════════════════════════════════════════\nfunction buildUI(){\n  \/\/ inbound csw\n  document.getElementById('in-csw').innerHTML = CATS.map(function(c){\n    return '<button class=\"cb'+(c==='drug'?' on':'')+'\" id=\"ic-'+c+'\" onclick=\"setInCat(\\''+c+'\\')\" style=\"'+(c==='drug'?'background:'+C[c].c+';color:#fff':'')+'\">'+C[c].i+' '+C[c].n+'<\/button>';\n  }).join('');\n  \/\/ outbound csw\n  document.getElementById('out-csw').innerHTML = CATS.map(function(c){\n    return '<button class=\"cb'+(c==='drug'?' on':'')+'\" id=\"oc-'+c+'\" onclick=\"setOutCat(\\''+c+'\\')\" style=\"'+(c==='drug'?'background:'+C[c].c+';color:#fff':'')+'\">'+C[c].i+' '+C[c].n+'<\/button>';\n  }).join('');\n  \/\/ query csw\n  document.getElementById('q-csw').innerHTML = CATS.map(function(c){\n    return '<button class=\"cb'+(c==='drug'?' on':'')+'\" id=\"qc-'+c+'\" onclick=\"setQCat(\\''+c+'\\');renderQ()\" style=\"'+(c==='drug'?'background:'+C[c].c+';color:#fff':'')+'\">'+C[c].i+' '+C[c].n+'<\/button>';\n  }).join('');\n  \/\/ history tabs\n  var htabs=[['all','全部'],['in','進貨'],['out','出貨'],['drug','💊 藥品'],['supply','🩺 醫療耗材'],['lab','🔬 檢驗耗材'],['food','🍖 處方飼料']];\n  document.getElementById('hist-tabs').innerHTML = htabs.map(function(t){\n    return '<button class=\"tabb'+(t[0]==='all'?' on':'')+'\" id=\"ht-'+t[0]+'\" onclick=\"switchHist(\\''+t[0]+'\\')\">'+t[1]+'<\/button>';\n  }).join('');\n  \/\/ fill in-unit\n  fillUnits('in-unit','drug');\n  \/\/ set in-date\n  document.getElementById('in-date').value = today();\n  document.getElementById('out-date').value = today();\n  \/\/ set dot colors\n  setDotColor('in-sdot','drug'); setDotColor('in-fdot','drug');\n  setDotColor('out-sdot','drug'); setDotColor('out-fdot','drug');\n  \/\/ set submit btn color\n  setBtnColor('in-submit','drug'); setBtnColor('out-submit','drug');\n}\nfunction setDotColor(id,cat){ document.getElementById(id).style.background=C[cat].c; }\nfunction setBtnColor(id,cat){ var b=document.getElementById(id); b.style.background=C[cat].c; b.style.color='#fff'; }\nfunction fillUnits(id,cat){\n  var sel=document.getElementById(id); sel.innerHTML='';\n  C[cat].u.forEach(function(u){ var o=document.createElement('option'); o.textContent=u; sel.appendChild(o); });\n}\nfunction setCatSw(prefix,cat){\n  CATS.forEach(function(c){\n    var el=document.getElementById(prefix+c); if(!el)return;\n    el.className='cb'+(c===cat?' on':'');\n    el.style.background=c===cat?C[c].c:'';\n    el.style.color=c===cat?'#fff':'';\n  });\n}\nfunction setInCat(cat){\n  inCat=cat; setCatSw('ic-',cat);\n  setDotColor('in-sdot',cat); setDotColor('in-fdot',cat);\n  setBtnColor('in-submit',cat); fillUnits('in-unit',cat);\n  clearIn(false);\n}\nfunction setOutCat(cat){\n  outCat=cat; setCatSw('oc-',cat);\n  setDotColor('out-sdot',cat); setDotColor('out-fdot',cat);\n  setBtnColor('out-submit',cat); clearOut();\n}\nfunction setQCat(cat){ qCat=cat; setCatSw('qc-',cat); }\n\n\/\/ ════════════════════════════════════════════════\n\/\/ INVENTORY\n\/\/ ════════════════════════════════════════════════\nfunction getInv(cat){\n  var inv={};\n  DB.forEach(function(r){\n    if(r.cat!==cat)return;\n    if(!inv[r.name]) inv[r.name]={qty:0,unit:r.unit,expiry:'',vendor:'',cost:null,price:null};\n    if(r.type==='in'){\n      inv[r.name].qty+=Number(r.qty);\n      if(r.cost!=null)  inv[r.name].cost=r.cost;\n      if(r.price!=null) inv[r.name].price=r.price;\n      if(!inv[r.name].expiry||(r.expiry&&r.expiry<inv[r.name].expiry))\n        inv[r.name].expiry=r.expiry||'';\n    } else {\n      inv[r.name].qty-=Number(r.qty);\n    }\n    if(r.unit)   inv[r.name].unit=r.unit;\n    if(r.vendor) inv[r.name].vendor=r.vendor;\n  });\n  return inv;\n}\nfunction getNames(cat){\n  var seen={},out=[];\n  DB.forEach(function(r){ if(r.type==='in'&&r.cat===cat&&!seen[r.name]){seen[r.name]=1;out.push(r.name);} });\n  return out;\n}\nfunction getVendors(name,cat){\n  var seen={},out=[];\n  DB.forEach(function(r){ if(r.type==='in'&&r.cat===cat&&r.name===name&&!seen[r.vendor]){seen[r.vendor]=1;out.push(r.vendor);} });\n  return out;\n}\n\n\/\/ ════════════════════════════════════════════════\n\/\/ HELPERS\n\/\/ ════════════════════════════════════════════════\nfunction fmtP(v){ return(v!=null&&v!=='')? 'NT$'+Number(v).toLocaleString():'-'; }\nfunction fmtM(cost,price){\n  if(cost==null||price==null)return '-';\n  var m=Number(price)-Number(cost);\n  var bg=m>=0?'rgba(58,107,74,.1)':'rgba(185,64,64,.1)';\n  var col=m>=0?'#3a6b4a':'#b94040';\n  return '<span class=\"pc\" style=\"background:'+bg+';color:'+col+'\">'+(m>=0?'+':'')+m.toLocaleString()+'<\/span>';\n}\nfunction daysLeft(exp){ if(!exp)return null; return Math.floor((new Date(exp)-new Date())\/86400000); }\nfunction expBadgeHtml(exp){\n  var d=daysLeft(exp); if(d===null)return '';\n  if(d<=0)  return badge('已過期','rgba(185,64,64,.12)','#b94040');\n  if(d<=30) return badge('剩'+d+'天','rgba(196,118,58,.12)','#c4763a');\n  return badge('剩'+d+'天','rgba(58,107,74,.12)','#3a6b4a');\n}\nfunction statusOf(v){\n  var d=daysLeft(v.expiry);\n  if(v.qty<=0)        return {b:badge('已用盡','#f0ede4','#8a8275'),hi:''};\n  if(d!==null&&d<=0)  return {b:badge('已過期','rgba(185,64,64,.12)','#b94040'),hi:'re'};\n  if(d!==null&&d<=30) return {b:badge('到期剩'+d+'天','rgba(196,118,58,.12)','#c4763a'),hi:'rl'};\n  if(v.qty<=10)       return {b:badge('庫存偏低','rgba(196,118,58,.12)','#c4763a'),hi:'rl'};\n  return                     {b:badge('正常','rgba(58,107,74,.12)','#3a6b4a'),hi:''};\n}\nfunction badge(txt,bg,col){\n  return '<span class=\"badge\" style=\"background:'+bg+';color:'+col+'\">'+txt+'<\/span>';\n}\nfunction catBadge(cat){\n  var bc={'drug':['rgba(58,107,74,.12)','#3a6b4a'],'supply':['rgba(58,94,140,.12)','#3a5e8c'],\n          'lab':['rgba(123,79,160,.12)','#7b4fa0'],'food':['rgba(176,106,42,.12)','#b06a2a']};\n  var p=bc[cat]||['#eee','#666']; var info=C[cat]||{i:'',n:cat};\n  return badge(info.i+' '+info.n,p[0],p[1]);\n}\nfunction esc(s){ return String(s).replace(\/\\\\\/g,'\\\\\\\\').replace(\/'\/g,\"\\\\'\"); }\n\n\/\/ ════════════════════════════════════════════════\n\/\/ DASHBOARD\n\/\/ ════════════════════════════════════════════════\nfunction renderDash(){\n  var t30=new Date(); t30.setDate(t30.getDate()+30);\n  var low=0,exp=0;\n  \/\/ stats top row\n  var cHtml='';\n  CATS.forEach(function(cat){\n    var inv=getInv(cat); var keys=Object.keys(inv);\n    keys.forEach(function(k){\n      var v=inv[k];\n      if(v.qty>0&&v.qty<=10)low++;\n      if(v.expiry&&v.qty>0&&new Date(v.expiry)<=t30)exp++;\n    });\n    cHtml+='<div class=\"sc\" style=\"border-left:3px solid '+C[cat].c+'\">'+\n      '<div class=\"sv\">'+keys.length+'<\/div>'+\n      '<div class=\"sl\">'+C[cat].i+' '+C[cat].n+'品項<\/div><\/div>';\n  });\n  document.getElementById('stats-cats').innerHTML=cHtml;\n  var vs={};\n  DB.forEach(function(r){if(r.type==='in')vs[r.vendor]=1;});\n  document.getElementById('s-vendors').textContent=Object.keys(vs).length;\n  document.getElementById('s-low').textContent=low;\n  document.getElementById('s-exp').textContent=exp;\n  \/\/ tables\n  var tHtml='';\n  CATS.forEach(function(cat){\n    var inv=getInv(cat); var entries=Object.entries(inv);\n    var rows='';\n    if(!entries.length){\n      rows='<tr><td colspan=\"8\"><div class=\"empty\">📭 尚無資料<\/div><\/td><\/tr>';\n    } else {\n      entries.forEach(function(e){\n        var name=e[0],v=e[1]; var s=statusOf(v);\n        rows+='<tr class=\"'+s.hi+'\">'+\n          '<td class=\"tbold\">'+name+'<\/td>'+\n          '<td>'+(v.vendor||'-')+'<\/td>'+\n          '<td class=\"tm\">'+v.qty+' '+v.unit+'<\/td>'+\n          '<td class=\"tm\">'+fmtP(v.cost)+'<\/td>'+\n          '<td class=\"tm\">'+fmtP(v.price)+'<\/td>'+\n          '<td>'+fmtM(v.cost,v.price)+'<\/td>'+\n          '<td class=\"tm\">'+(v.expiry||'-')+'<\/td>'+\n          '<td>'+s.b+'<\/td><\/tr>';\n      });\n    }\n    tHtml+='<div class=\"card\">'+\n      '<div class=\"card-ttl\"><span class=\"dot\" style=\"background:'+C[cat].c+'\"><\/span>'+C[cat].i+' '+C[cat].n+'庫存<\/div>'+\n      '<div class=\"twrap\"><table><thead><tr>'+\n      '<th>品名<\/th><th>廠商<\/th><th>現有數量<\/th><th>進貨成本<\/th><th>售價<\/th><th>毛利\/單位<\/th><th>有效期限<\/th><th>狀態<\/th>'+\n      '<\/tr><\/thead><tbody>'+rows+'<\/tbody><\/table><\/div><\/div>';\n  });\n  document.getElementById('dash-tables').innerHTML=tHtml;\n}\n\n\/\/ ════════════════════════════════════════════════\n\/\/ INBOUND\n\/\/ ════════════════════════════════════════════════\nfunction searchIn(){\n  var val=document.getElementById('in-srch').value.trim();\n  var list=document.getElementById('in-ac');\n  var vArea=document.getElementById('in-vtag-area');\n  if(!val){list.classList.remove('on');vArea.style.display='none';return;}\n  var names=getNames(inCat).filter(function(n){return n.indexOf(val)>=0;});\n  if(!names.length){list.classList.remove('on');vArea.style.display='none';return;}\n  var inv=getInv(inCat);\n  list.innerHTML=names.map(function(n){\n    var q=inv[n]?inv[n].qty+' '+inv[n].unit:'-';\n    return '<div class=\"aci\" onclick=\"pickProduct(\\''+esc(n)+'\\')\"><span>'+n+'<\/span><span class=\"aci-s\">庫存：'+q+'<\/span><\/div>';\n  }).join('');\n  list.classList.add('on');\n}\nfunction pickProduct(name){\n  document.getElementById('in-srch').value=name;\n  document.getElementById('in-name').value=name;\n  document.getElementById('in-ac').classList.remove('on');\n  var vendors=getVendors(name,inCat);\n  var vArea=document.getElementById('in-vtag-area');\n  if(vendors.length){\n    vArea.style.display='block';\n    document.getElementById('in-vtags').innerHTML=vendors.map(function(v){\n      return '<button class=\"vtag\" onclick=\"pickVendor(\\''+esc(v)+'\\',this)\">'+v+'<\/button>';\n    }).join('');\n  } else { vArea.style.display='none'; }\n  var inv=getInv(inCat);\n  if(inv[name]){\n    document.getElementById('in-unit').value=inv[name].unit;\n    if(inv[name].cost!=null)  document.getElementById('in-cost').value=inv[name].cost;\n    if(inv[name].price!=null) document.getElementById('in-price').value=inv[name].price;\n  }\n}\nfunction pickVendor(v,el){\n  document.querySelectorAll('.vtag').forEach(function(t){t.classList.remove('on');});\n  el.classList.add('on');\n  document.getElementById('in-vendor').value=v;\n}\nfunction submitIn(){\n  var name=  document.getElementById('in-name').value.trim();\n  var vendor=document.getElementById('in-vendor').value.trim();\n  var date=  document.getElementById('in-date').value;\n  var expiry=document.getElementById('in-expiry').value;\n  var qty=   document.getElementById('in-qty').value;\n  var unit=  document.getElementById('in-unit').value;\n  var cost=  document.getElementById('in-cost').value;\n  var price= document.getElementById('in-price').value;\n  var note=  document.getElementById('in-note').value.trim();\n  if(!name||!vendor||!date||!qty){showToast('⚠ 請填寫必填欄位（品名、廠商、日期、數量）',true);return;}\n  if(Number(qty)<=0){showToast('⚠ 數量必須大於 0',true);return;}\n  DB.push({type:'in',cat:inCat,name:name,vendor:vendor,date:date,expiry:expiry,\n    qty:Number(qty),unit:unit,\n    cost:cost!==''?Number(cost):null,\n    price:price!==''?Number(price):null,\n    note:note,id:Date.now()});\n  save(); showToast('✅ 進貨登記成功：'+name+' '+qty+unit); clearIn(false);\n}\nfunction clearIn(full){\n  if(full!==false) document.getElementById('in-srch').value='';\n  ['in-name','in-vendor','in-expiry','in-qty','in-cost','in-price','in-note'].forEach(function(id){\n    document.getElementById(id).value='';\n  });\n  document.getElementById('in-date').value=today();\n  document.getElementById('in-vtag-area').style.display='none';\n}\n\n\/\/ ════════════════════════════════════════════════\n\/\/ OUTBOUND\n\/\/ ════════════════════════════════════════════════\nfunction searchOut(){\n  var val=document.getElementById('out-srch').value.trim();\n  var list=document.getElementById('out-ac');\n  if(!val){list.classList.remove('on');return;}\n  var inv=getInv(outCat);\n  var products=Object.keys(inv).filter(function(p){return p.indexOf(val)>=0&&inv[p].qty>0;});\n  if(!products.length){list.classList.remove('on');return;}\n  list.innerHTML=products.map(function(p){\n    return '<div class=\"aci\" onclick=\"pickOut(\\''+esc(p)+'\\')\"><span>'+p+'<\/span><span class=\"aci-s\">庫存：'+inv[p].qty+' '+inv[p].unit+'<\/span><\/div>';\n  }).join('');\n  list.classList.add('on');\n}\nfunction pickOut(name){\n  document.getElementById('out-srch').value=name;\n  document.getElementById('out-ac').classList.remove('on');\n  document.getElementById('out-name').value=name;\n  var v=getInv(outCat)[name];\n  document.getElementById('out-unit').value=v.unit;\n  var d=daysLeft(v.expiry);\n  var expStr=v.expiry?v.expiry+(d!==null?'（'+(d>0?'剩'+d+'天':'已過期')+'）':''):'未登記';\n  var info=document.getElementById('out-info');\n  info.style.display='block';\n  info.innerHTML='現有庫存：<strong>'+v.qty+' '+v.unit+'<\/strong>　有效期限：'+expStr+'<br>進貨成本：'+fmtP(v.cost)+'　售價：'+fmtP(v.price)+'　廠商：'+(v.vendor||'-');\n}\nfunction submitOut(){\n  var name=document.getElementById('out-name').value.trim();\n  var date=document.getElementById('out-date').value;\n  var qty=Number(document.getElementById('out-qty').value);\n  var unit=document.getElementById('out-unit').value;\n  var note=document.getElementById('out-note').value.trim();\n  if(!name||!date||!qty){showToast('⚠ 請填寫完整資料',true);return;}\n  var inv=getInv(outCat);\n  if(!inv[name]){showToast('⚠ 找不到此品項',true);return;}\n  if(qty>inv[name].qty){showToast('⚠ 出貨量超過庫存（庫存：'+inv[name].qty+unit+'）',true);return;}\n  DB.push({type:'out',cat:outCat,name:name,vendor:inv[name].vendor,date:date,\n    expiry:inv[name].expiry,qty:qty,unit:unit,\n    cost:inv[name].cost,price:inv[name].price,note:note,id:Date.now()});\n  save(); showToast('✅ 出貨登記成功：'+name+' '+qty+unit); clearOut();\n}\nfunction clearOut(){\n  ['out-srch','out-name','out-qty','out-unit','out-note'].forEach(function(id){\n    document.getElementById(id).value='';\n  });\n  document.getElementById('out-date').value=today();\n  document.getElementById('out-info').style.display='none';\n}\n\n\/\/ ════════════════════════════════════════════════\n\/\/ QUERY\n\/\/ ════════════════════════════════════════════════\nfunction renderQ(){\n  var q=document.getElementById('q-input').value.trim().toLowerCase();\n  var inv=getInv(qCat);\n  var area=document.getElementById('q-result');\n  var entries=Object.entries(inv).filter(function(e){return !q||e[0].toLowerCase().indexOf(q)>=0;});\n  if(!entries.length){area.innerHTML='<div class=\"empty\">🔍 找不到相符品項<\/div>';return;}\n  var html='';\n  entries.forEach(function(e){\n    var name=e[0],v=e[1];\n    var eb=expBadgeHtml(v.expiry);\n    var hRows='';\n    DB.forEach(function(r){\n      if(r.name!==name||r.cat!==qCat)return;\n      hRows+='<tr>'+\n        '<td class=\"tm\">'+r.date+'<\/td>'+\n        '<td>'+(r.type==='in'?badge('進貨','rgba(58,107,74,.12)','#3a6b4a'):badge('出貨','rgba(196,118,58,.12)','#c4763a'))+'<\/td>'+\n        '<td class=\"tm\">'+(r.type==='in'?'+':'-')+r.qty+' '+r.unit+'<\/td>'+\n        '<td class=\"tm\">'+fmtP(r.cost)+'<\/td>'+\n        '<td class=\"tm\">'+fmtP(r.price)+'<\/td>'+\n        '<td>'+(r.vendor||'-')+'<\/td>'+\n        '<td>'+(r.note||'-')+'<\/td><\/tr>';\n    });\n    html+='<div class=\"card\">'+\n      '<div style=\"display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:11px;margin-bottom:12px\">'+\n      '<div>'+\n      '<div style=\"display:flex;align-items:center;gap:8px;flex-wrap:wrap\">'+\n      '<div style=\"font-size:17px;font-weight:700\">'+name+'<\/div>'+catBadge(qCat)+'<\/div>'+\n      '<div style=\"font-size:11.5px;color:var(--t3);margin-top:6px;line-height:2\">'+\n      '廠商：'+(v.vendor||'-')+'　｜　有效期限：'+(v.expiry||'未登記')+' '+eb+'<br>'+\n      '進貨成本：'+fmtP(v.cost)+'　｜　售價：'+fmtP(v.price)+'　｜　毛利\/單位：'+fmtM(v.cost,v.price)+'<\/div><\/div>'+\n      '<div style=\"text-align:right\">'+\n      '<div style=\"font-size:26px;font-weight:600;color:'+C[qCat].c+'\">'+v.qty+' <span style=\"font-size:13px\">'+v.unit+'<\/span><\/div>'+\n      '<div style=\"font-size:10.5px;color:var(--t3)\">現有庫存<\/div><\/div><\/div>'+\n      '<div class=\"twrap\"><table><thead><tr>'+\n      '<th>日期<\/th><th>類型<\/th><th>數量<\/th><th>進貨成本<\/th><th>售價<\/th><th>廠商<\/th><th>備註<\/th>'+\n      '<\/tr><\/thead><tbody>'+(hRows||'<tr><td colspan=\"7\" style=\"text-align:center;color:var(--t3);padding:13px\">尚無記錄<\/td><\/tr>')+\n      '<\/tbody><\/table><\/div><\/div>';\n  });\n  area.innerHTML=html;\n}\n\n\/\/ ════════════════════════════════════════════════\n\/\/ HISTORY\n\/\/ ════════════════════════════════════════════════\nfunction switchHist(tab){\n  histTab=tab;\n  document.querySelectorAll('.tabb').forEach(function(b){b.classList.remove('on');});\n  document.getElementById('ht-'+tab).classList.add('on');\n  renderHist();\n}\nfunction renderHist(){\n  var f=DB.filter(function(r){\n    if(histTab==='in')  return r.type==='in';\n    if(histTab==='out') return r.type==='out';\n    if(CATS.indexOf(histTab)>=0) return r.cat===histTab;\n    return true;\n  }).slice().reverse();\n  var tb=document.getElementById('hist-body');\n  if(!f.length){\n    tb.innerHTML='<tr><td colspan=\"11\"><div class=\"empty\">📋 尚無記錄<\/div><\/td><\/tr>';\n    return;\n  }\n  tb.innerHTML=f.map(function(r){\n    return '<tr>'+\n      '<td class=\"tm\">'+r.date+'<\/td>'+\n      '<td>'+(r.type==='in'?badge('進貨','rgba(58,107,74,.12)','#3a6b4a'):badge('出貨','rgba(196,118,58,.12)','#c4763a'))+'<\/td>'+\n      '<td>'+catBadge(r.cat)+'<\/td>'+\n      '<td class=\"tbold\">'+r.name+'<\/td>'+\n      '<td>'+(r.vendor||'-')+'<\/td>'+\n      '<td class=\"tm\">'+(r.type==='in'?'+':'-')+r.qty+' '+r.unit+'<\/td>'+\n      '<td class=\"tm\">'+fmtP(r.cost)+'<\/td>'+\n      '<td class=\"tm\">'+fmtP(r.price)+'<\/td>'+\n      '<td class=\"tm\">'+(r.expiry||'-')+'<\/td>'+\n      '<td>'+(r.note||'-')+'<\/td>'+\n      '<td><button onclick=\"delRec('+r.id+')\" style=\"background:rgba(185,64,64,.1);color:#b94040;border:none;padding:4px 10px;border-radius:6px;cursor:pointer;font-size:11.5px;font-family:inherit\">刪除<\/button><\/td><\/tr>';\n  }).join('');\n}\nfunction delRec(id){\n  if(!confirm('確定要刪除此記錄？'))return;\n  DB=DB.filter(function(r){return r.id!==id;});\n  save(); renderHist(); showToast('記錄已刪除');\n}\n\n\/\/ ════════════════════════════════════════════════\n\/\/ EXPORT CSV\n\/\/ ════════════════════════════════════════════════\nfunction exportCSV(){\n  var h=['日期','類型','分類','品名','廠商','數量','單位','進貨成本','售價','有效期限','備註'];\n  var rows=DB.map(function(r){\n    var cat=C[r.cat]||{i:'',n:r.cat};\n    return [r.date,r.type==='in'?'進貨':'出貨',cat.i+' '+cat.n,\n      r.name,r.vendor||'',r.qty,r.unit,\n      r.cost!=null?r.cost:'',r.price!=null?r.price:'',r.expiry||'',r.note||''];\n  });\n  var csv=[h].concat(rows).map(function(r){\n    return r.map(function(c){return '\"'+String(c).replace(\/\"\/g,'\"\"')+'\"';}).join(',');\n  }).join('\\n');\n  var a=document.createElement('a');\n  a.href=URL.createObjectURL(new Blob(['\\uFEFF'+csv],{type:'text\/csv;charset=utf-8'}));\n  a.download='路米動物醫院進出貨記錄.csv'; a.click();\n  showToast('✅ CSV 匯出成功');\n}\n\n\/\/ ════════════════════════════════════════════════\n\/\/ SYNC\n\/\/ ════════════════════════════════════════════════\nfunction getUrl(){ return localStorage.getItem('lumi_url')||''; }\nfunction openSync(){\n  var u=getUrl();\n  if(u) document.getElementById('sync-url').value=u;\n  document.getElementById('sync-status').style.display='none';\n  document.getElementById('sync-overlay').classList.add('on');\n}\nfunction closeSync(){ document.getElementById('sync-overlay').classList.remove('on'); }\nfunction setSyncSt(msg,type){\n  var el=document.getElementById('sync-status');\n  el.style.display='block'; el.textContent=msg;\n  var bg=type==='ok'?'rgba(58,107,74,.1)':type==='w'?'rgba(196,118,58,.1)':type==='err'?'rgba(185,64,64,.1)':'var(--sur2)';\n  var col=type==='ok'?'#3a6b4a':type==='w'?'#c4763a':type==='err'?'#b94040':'var(--t2)';\n  el.style.background=bg; el.style.color=col;\n  el.style.border='1px solid '+bg; el.style.borderRadius='8px'; el.style.padding='11px 13px';\n}\nfunction saveUrl(){\n  var url=document.getElementById('sync-url').value.trim();\n  if(url.indexOf('script.google.com')<0){setSyncSt('⚠ 請貼上正確的 Apps Script 網址','w');return;}\n  localStorage.setItem('lumi_url',url); setSyncSt('✅ 網址已儲存','ok');\n}\nfunction testConn(){\n  var url=getUrl(); if(!url){setSyncSt('⚠ 請先儲存網址','w');return;}\n  setSyncSt('🔌 測試連線中...','');\n  fetch(url+'?action=ping',{method:'GET',mode:'no-cors'})\n    .then(function(){ setSyncSt('✅ 連線成功！Apps Script 正常運作','ok'); })\n    .catch(function(e){ setSyncSt('❌ 連線失敗：'+e.message,'err'); });\n}\nfunction initSheets(){\n  var url=getUrl(); if(!url){setSyncSt('⚠ 請先儲存網址','w');return;}\n  setSyncSt('📋 初始化中...','');\n  fetch(url,{method:'POST',mode:'no-cors',\n    headers:{'Content-Type':'application\/json'},\n    body:JSON.stringify({action:'setup'})\n  }).then(function(){ setSyncSt('✅ 試算表初始化完成！','ok'); })\n    .catch(function(e){ setSyncSt('❌ 失敗：'+e.message,'err'); });\n}\nfunction doSync(){\n  var url=getUrl(); if(!url){setSyncSt('⚠ 請先儲存網址','w');return;}\n  if(!DB.length){setSyncSt('⚠ 沒有資料可同步','w');return;}\n  var btn=document.getElementById('do-sync-btn');\n  btn.disabled=true; btn.textContent='同步中...';\n  setSyncSt('⏳ 正在同步 '+DB.length+' 筆紀錄...','');\n  fetch(url,{method:'POST',mode:'no-cors',\n    headers:{'Content-Type':'application\/json'},\n    body:JSON.stringify({action:'sync',records:DB})\n  }).then(function(){\n    var now=new Date().toLocaleString('zh-TW');\n    localStorage.setItem('lumi_last_sync',now);\n    setSyncSt('✅ 同步完成！共 '+DB.length+' 筆\\n時間：'+now,'ok');\n    showToast('✅ 已同步到 Google 試算表');\n  }).catch(function(e){\n    setSyncSt('❌ 同步失敗：'+e.message,'err');\n  }).finally(function(){\n    btn.disabled=false; btn.textContent='🔄 立即同步';\n  });\n}\n\n\/\/ ════════════════════════════════════════════════\n\/\/ TOAST\n\/\/ ════════════════════════════════════════════════\nvar _tt;\nfunction showToast(msg,warn){\n  var t=document.getElementById('toast');\n  t.textContent=msg; t.style.background=warn?'#c4763a':'#3a6b4a';\n  t.style.display='block'; t.style.opacity='1';\n  clearTimeout(_tt);\n  _tt=setTimeout(function(){ t.style.opacity='0'; setTimeout(function(){t.style.display='none';},300); },2800);\n}\n\n\/\/ ════════════════════════════════════════════════\n\/\/ CLOSE AUTOCOMPLETE ON OUTSIDE CLICK\n\/\/ ════════════════════════════════════════════════\ndocument.addEventListener('click',function(e){\n  if(!e.target.closest('.acw'))\n    document.querySelectorAll('.acl').forEach(function(l){l.classList.remove('on');});\n});\n\n\/\/ ════════════════════════════════════════════════\n\/\/ DEMO DATA\n\/\/ ════════════════════════════════════════════════\nfunction DEMO_DATA(){\n  return [\n    {type:'in', cat:'drug',   name:'Amoxicillin 250mg',      vendor:'台灣武田',   date:'2025-01-10',expiry:'2026-06-30',qty:200,unit:'顆',cost:3.5, price:8,   note:'批號A001',id:1},\n    {type:'in', cat:'drug',   name:'Metronidazole 500mg',     vendor:'信東生技',   date:'2025-02-01',expiry:'2026-08-15',qty:150,unit:'顆',cost:5,   price:12,  note:'',        id:2},\n    {type:'in', cat:'drug',   name:'Prednisolone 5mg',        vendor:'台灣武田',   date:'2025-02-15',expiry:'2025-12-31',qty:100,unit:'粒',cost:4,   price:10,  note:'',        id:3},\n    {type:'out',cat:'drug',   name:'Amoxicillin 250mg',       vendor:'台灣武田',   date:'2025-03-10',expiry:'2026-06-30',qty:20, unit:'顆',cost:3.5, price:8,   note:'Mimi治療',id:4},\n    {type:'in', cat:'supply', name:'一次性注射針筒 5ml',      vendor:'台灣三孔',   date:'2025-01-20',expiry:'2028-01-01',qty:500,unit:'支',cost:2,   price:5,   note:'',        id:5},\n    {type:'in', cat:'supply', name:'外科手套 M號',            vendor:'合成橡膠',   date:'2025-03-01',expiry:'2028-03-01',qty:50, unit:'包',cost:60,  price:130, note:'',        id:6},\n    {type:'out',cat:'supply', name:'一次性注射針筒 5ml',      vendor:'台灣三孔',   date:'2025-03-15',expiry:'2028-01-01',qty:50, unit:'支',cost:2,   price:5,   note:'日常診療',id:7},\n    {type:'in', cat:'lab',    name:'血糖試紙',                vendor:'羅氏診斷',   date:'2025-01-15',expiry:'2026-03-01',qty:100,unit:'片',cost:8,   price:18,  note:'',        id:8},\n    {type:'in', cat:'lab',    name:'快篩試劑 CPV',            vendor:'IDEXX',      date:'2025-03-01',expiry:'2026-09-01',qty:20, unit:'盒',cost:350, price:700, note:'',        id:9},\n    {type:'out',cat:'lab',    name:'快篩試劑 CPV',            vendor:'IDEXX',      date:'2025-03-20',expiry:'2026-09-01',qty:3,  unit:'盒',cost:350, price:700, note:'犬瘟篩檢',id:10},\n    {type:'in', cat:'food',   name:'Hills c\/d 泌尿道處方',    vendor:'希爾思',     date:'2025-01-10',expiry:'2026-01-01',qty:30, unit:'包',cost:450, price:820, note:'',        id:11},\n    {type:'in', cat:'food',   name:'NexGard 驅蟲藥 S',        vendor:'Boehringer', date:'2025-03-01',expiry:'2027-03-01',qty:60, unit:'盒',cost:220, price:450, note:'',        id:12},\n    {type:'out',cat:'food',   name:'NexGard 驅蟲藥 S',        vendor:'Boehringer', date:'2025-03-25',expiry:'2027-03-01',qty:10, unit:'盒',cost:220, price:450, note:'預防用藥',id:13}\n  ];\n}\n\n\/\/ ════════════════════════════════════════════════\n\/\/ INIT\n\/\/ ════════════════════════════════════════════════\nbuildUI();\nrenderDash();\n<\/script>\n<\/body>\n<\/html>
